# CUE Backend — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — defaults shown
PORT=3000
GEMINI_MODEL=gemini-2.5-flash-lite

# In production: lock CORS to your specific extension ID
# Get it from chrome://extensions after loading the unpacked extension
# Then update CORS_OPTIONS in server.js to check against this value
# ALLOWED_ORIGIN=chrome-extension://YOUR_EXTENSION_ID_HERE
