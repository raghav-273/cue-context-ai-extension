{
  "manifest_version": 3,
  "name": "CUE — Contextual Intelligence",
  "version": "4.0.0",
  "description": "AI-powered contextual intelligence layer for the web. Understands any page, remembers your sessions, thinks with you.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "contextMenus"
  ],

  "host_permissions": [
    "http://localhost:3000/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CUE"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/core/config.js",
        "src/core/events.js",
        "src/core/state.js",
        "src/core/storage.js",
        "src/core/api.js",
        "src/core/context.js",
        "src/utils/dom.js",
        "src/utils/markdown.js",
        "src/utils/time.js",
        "src/ui/sidebar.js",
        "src/ui/messages.js",
        "src/ui/command-palette.js",
        "src/ui/highlight-tooltip.js",
        "src/ui/shortcuts.js",
        "src/features/page-dna.js",
        "src/features/smart-suggest.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["content.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}