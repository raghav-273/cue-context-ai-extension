{
  "manifest_version": 3,
  "name": "CUE — Contextual Web Assistant",
  "version": "2.0.0",
  "description": "AI-powered contextual assistant that understands any webpage and provides intelligent insights in real-time.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CUE Assistant"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/utils/dom.js",
        "src/utils/markdown.js",
        "src/core/config.js",
        "src/core/storage.js",
        "src/core/context.js",
        "src/core/api.js",
        "src/core/state.js",
        "src/ui/sidebar.js",
        "src/ui/messages.js",
        "src/ui/shortcuts.js",
        "src/ui/message-handler.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}